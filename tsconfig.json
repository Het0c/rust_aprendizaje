{
  "compilerOptions": {
    /* Este archivo le dice a TypeScript CÓMO revisar y compilar nuestro código.
       No genera la app final (eso lo hace Vite), pero sí nos avisa de errores
       de tipos ANTES de ejecutar nada, lo cual ahorra muchísimos bugs. */

    "target": "ES2020",              // Versión de JavaScript de salida.
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"], // APIs disponibles (incluye el navegador).
    "module": "ESNext",
    "skipLibCheck": true,

    /* Modo "bundler": dejamos que Vite resuelva los imports, TypeScript solo
       revisa tipos. */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,        // Permite hacer import de archivos .json (¡clave para nuestra "base de datos" simulada!).
    "isolatedModules": true,
    "noEmit": true,                   // TypeScript no genera JS, solo verifica tipos.
    "jsx": "react-jsx",               // Habilita la sintaxis JSX (<Componente />).

    /* Reglas estrictas: nos obligan a escribir código más seguro. */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
